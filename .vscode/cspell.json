{
    "version": "0.2",
    "enabled": true,
    "language": "en,en-US",
    "minWordLength": 4,
    "numSuggestions": 8,
    "useGitignore": true,
    "allowCompoundWords": false,
    "languageSettings": [
        {
            "languageId": "*",
            "locale": "en",
            "dictionaries": [
                "wordsEn"
            ]
        },
        {
            "languageId": "python",
            "dictionaries": [
                "python"
            ]
        },
        {
            "languageId": "markdown",
            "dictionaries": [
                "markdown"
            ]
        }
    ],
    "flagWords": [
        "hte"
    ],
    "words": [
        "addopts",
        "dataclasses",
        "docstrings",
        "filmu",
        "httpx",
        "imdbid",
        "Jellyfin",
        "Jméno",
        "MULTISPACE",
        "pathlib",
        "Pokorny",
        "Pydantic",
        "pytest",
        "pythonpath",
        "rapidfuzz",
        "respx",
        "rtype",
        "testpaths",
        "tmdb",
        "tmdbid",
        "TVDB",
        "tvdbid",
        "venv",
        "Witcher",
        "Zdenek"
    ],
    "ignoreWords": [
        "bluray",
        "brrip",
        "bdrip",
        "webrip",
        "web-dl",
        "webdl",
        "dvdrip",
        "hdrip",
        "x264",
        "x265",
        "h264",
        "h265",
        "hevc",
        "aac",
        "dts",
        "ac3",
        "proper",
        "repack",
        "remux",
        "delenv"
    ],
    "ignorePaths": [
        "package-lock.json",
        "vscode-extension",
        ".git",
        ".vscode",
        "uv.lock"
    ]
}
